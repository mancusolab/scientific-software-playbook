{
  "hooks": [
    {
      "event": "SessionStart",
      "matcher": "*",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-start.sh"
    },
    {
      "event": "PostToolUse",
      "matcher": "Edit|Write|MultiEdit",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/post-edit.sh"
    },
    {
      "event": "Stop",
      "matcher": "*",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/stop.sh"
    }
  ]
}
